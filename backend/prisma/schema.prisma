generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(consumer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipments        Shipment[]  @relation("ConsumerShipments")
  assignedIncidents Incident[] @relation("AssignedIncidents")

  @@map("users")
}

model Shipment {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  caseId          Int            @unique
  trackingId      String         @unique
  consumerId      String         @db.ObjectId
  consumer        User           @relation("ConsumerShipments", fields: [consumerId], references: [id])
  status          ShipmentStatus @default(pending)
  priority        Priority       @default(medium)
  origin          Location
  destination     Location
  currentLocation Location?
  carrierId       String?        @db.ObjectId
  carrier         Carrier?       @relation(fields: [carrierId], references: [id])
  warehouseId     String?        @db.ObjectId
  warehouse       Warehouse?     @relation(fields: [warehouseId], references: [id])
  initialEta      DateTime?
  finalEta        DateTime?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  delay           Int            @default(0)
  value           Float          @default(0)
  weight          Float?
  dimensions      Dimensions?
  routeHistory    RoutePoint[]
  routeWaypoints  RouteWaypoint[]
  slaDeadline     DateTime?
  slaBreached     Boolean        @default(false)
  rerouted        Boolean        @default(false)
  escalated       Boolean        @default(false)
  riskScore       Float          @default(0)
  agentNotes      String?
  previousCarrierId String?
  nextWarehouseId   String?
  deliveryAddress   String?
  recipientName     String?
  recipientPhone    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  incidents       Incident[]
  chatHistory     ChatHistory?

  @@index([consumerId])
  @@index([carrierId])
  @@index([warehouseId])
  @@index([status])
  @@map("shipments")
}

model Carrier {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  code            String   @unique
  reliabilityScore Float   @default(80)
  avgDeliveryTime Float?
  activeShipments Int      @default(0)
  totalDeliveries Int      @default(0)
  onTimeRate      Float    @default(95)
  failureRate     Float    @default(2)
  regions         String[]
  isActive        Boolean  @default(true)
  lastIncident    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shipments       Shipment[]

  @@map("carriers")
}

model Warehouse {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  code            String          @unique
  location        Location
  capacity        Int             @default(1000)
  currentLoad     Int             @default(0)
  utilizationPct  Float           @default(0)
  throughputRate   Float          @default(100)
  status          WarehouseStatus @default(operational)
  congestionLevel CongestionLevel @default(low)
  avgProcessTime  Float           @default(2)
  regions         String[]
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  shipments       Shipment[]
  inventoryItems  InventoryItem[]

  @@map("warehouses")
}

model InventoryItem {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  sku         String
  name        String
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  reorderPoint Int     @default(10)
  warehouseId String    @db.ObjectId
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  lastRestocked DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([sku, warehouseId])
  @@index([warehouseId])
  @@map("inventory_items")
}

model Incident {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  incidentId      String         @unique
  shipmentId      String?        @db.ObjectId
  shipment        Shipment?      @relation(fields: [shipmentId], references: [id])
  assignedAgentId String?        @db.ObjectId
  assignedAgent   User?          @relation("AssignedIncidents", fields: [assignedAgentId], references: [id])
  type            IncidentType
  severity        Severity       @default(medium)
  status          IncidentStatus @default(open)
  title           String
  description     String?
  rootCause       String?
  resolution      String?
  isEscalated     Boolean        @default(false)
  escalatedAt     DateTime?
  agentDecision   AgentDecision?
  riskScore       Float          @default(0)
  affectedCount   Int            @default(1)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  chatHistory     ChatHistory?

  @@index([shipmentId])
  @@index([assignedAgentId])
  @@index([status])
  @@index([type])
  @@map("incidents")
}

model ChatHistory {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  sessionId  String        @unique @db.ObjectId
  shipment   Shipment?     @relation(fields: [sessionId], references: [id])
  incidentId String?       @unique @db.ObjectId
  incident   Incident?     @relation(fields: [incidentId], references: [id])
  messages   ChatMessage[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("chat_histories")
}

model Log {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  logId     String   @unique
  timestamp DateTime @default(now())
  eventType String
  source    String
  severity  String
  message   String
  traceId   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([timestamp])
  @@index([eventType])
  @@index([source])
  @@map("logs")
}

model AgentAction {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  actionId      String   @unique
  actionType    String
  targetType    String
  targetId      String
  description   String
  reasoning     String?
  confidence    Float    @default(0)
  outcome       String?
  wasCorrect    Boolean?
  requiredHuman Boolean  @default(false)
  executedAt    DateTime @default(now())
  evaluatedAt   DateTime?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([actionType])
  @@index([executedAt])
  @@map("agent_actions")
}

type Location {
  lat     Float
  lng     Float
  address String?
  city    String?
  region  String?
}

type Dimensions {
  length Float
  width  Float
  height Float
  unit   String @default("cm")
}

type RoutePoint {
  lat       Float
  lng       Float
  label     String?
  timestamp DateTime @default(now())
  status    String?
}

type AgentDecision {
  action      String
  reasoning   String
  confidence  Float
  autonomous  Boolean  @default(false)
  approvedBy  String?
  executedAt  DateTime?
}

type RouteWaypoint {
  warehouseCode String
  warehouseName String
  city          String
  region        String
  lat           Float
  lng           Float
  order         Int
  status        String  @default("pending")
  arrivedAt     DateTime?
  departedAt    DateTime?
}

type ChatMessage {
  role            String
  content         String
  timestamp       DateTime @default(now())
  cards           Json?
  toolsUsed       String[]
  actionsTaken    String[]
  reasoning       Json?
  confidenceScore Int?
  complexityScore Int?
  isHuman         Boolean  @default(false)
}

enum ShipmentStatus {
  pending
  picked_up
  in_transit
  at_warehouse
  out_for_delivery
  delivered
  delayed
  cancelled
  returned
  lost
}

enum IncidentType {
  delay
  damage
  lost_package
  wrong_route
  warehouse_congestion
  carrier_failure
  sla_breach
  inventory_mismatch
  eta_deviation
  cascading_delay
  weather_disruption
  customs_hold
}

enum IncidentStatus {
  open
  investigating
  in_progress
  escalated
  resolved
  closed
}

enum Severity {
  low
  medium
  high
  critical
}

enum Priority {
  low
  medium
  high
  urgent
}

enum WarehouseStatus {
  operational
  degraded
  congested
  offline
  maintenance
}

enum CongestionLevel {
  low
  moderate
  high
  critical
}

enum UserRole {
  consumer
  admin
}
